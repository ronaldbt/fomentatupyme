{
  "name": "frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "optimize:images": "node scripts/optimize-images.mjs",
    "seo:audit": "node scripts/seo-audit.mjs",
    "build": "npm run optimize:images && nuxt build",
    "build:seo": "npm run build && npm run seo:audit",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "deploy": "nuxt generate && firebase deploy --only hosting",
    "deploy:redirect": "firebase deploy --only hosting:fomentatupyme-redirect",
    "cloudflare:www-redirect": "node scripts/setup-cloudflare-www-redirect.mjs"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@lucide/vue": "^1.16.0",
    "@nuxt/content": "^3.14.0",
    "@nuxtjs/robots": "^6.0.8",
    "@nuxtjs/sitemap": "^8.0.15",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "nuxt": "^4.4.5",
    "nuxt-site-config": "^4.0.8",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.34",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  }
}
